# SPA fallback: عند الريفرش على أي مسار (مثل /grammatik/A1/...) يعيد السيرفر index.html
# عشان React Router يقرأ المسار ويعرض الصفحة الصحيحة بدل صفحة بيضاء
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  # لا تعيد كتابة طلبات الملفات والأدلة الموجودة فعلياً
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
